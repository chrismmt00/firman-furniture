# Local development environment template.
# Copy to .env.local and fill in real values.

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Neon / PostgreSQL
# DATABASE_URL: pooled connection used by the app at runtime (Neon pgBouncer endpoint,
#   host contains "-pooler"). Locally this is your direct localhost connection.
# DIRECT_URL: unpooled connection used ONLY by `prisma migrate` / introspection.
#   On Neon this is the non-pooler host; locally it can equal DATABASE_URL.
DATABASE_URL=
DIRECT_URL=

# Auth.js
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Sentry error tracking (optional — everything no-ops when unset)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Brevo
BREVO_API_KEY=
BREVO_SENDER_EMAIL=hello@firmanfurniture.com
BREVO_SENDER_NAME=Firman Furniture

# ── Not currently wired ─────────────────────────────────────────────
# Reserved for planned integrations; nothing in the app reads these yet.
# Cloudflare Images (product image hosting)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_IMAGES_API_TOKEN=
CLOUDFLARE_IMAGES_DELIVERY_URL=
# External search (the search overlay currently uses a built-in local index)
SEARCH_PROVIDER=
MEILISEARCH_HOST=
MEILISEARCH_API_KEY=
ALGOLIA_APP_ID=
ALGOLIA_ADMIN_API_KEY=
NEXT_PUBLIC_ALGOLIA_SEARCH_API_KEY=
NEXT_PUBLIC_ALGOLIA_INDEX_NAME=
