# Production environment template for Vercel.
# Set these in the Vercel dashboard or with `vercel env add`.

NEXT_PUBLIC_SITE_URL=https://www.firmanfurniture.com

# Neon / PostgreSQL
DATABASE_URL=

# Auth.js
AUTH_SECRET=
